# ============================================================================
# Destin Bonfire Company - environment variables
# ============================================================================
# Copy this file to .env.local for local development, and set the same vars
# in the Vercel project dashboard for production.
#
# .env.local should NEVER be committed. .env.example is the template.
# ============================================================================

# ---------------------------------------------------------------------------
# Contact form - email delivery mode
# ---------------------------------------------------------------------------
# Controls how the /api/contact route delivers submissions. Default is
# log_only so the FIRST deploy never loses an inquiry, even if you haven't
# set up Resend yet. Submissions go to logs/contact-submissions.json.
#
# Modes:
#   "log_only"         - skip email entirely; only write to logs/contact-submissions.json
#                        (SAFE DEFAULT for initial deploys - nothing to configure, nothing lost)
#   "resend"           - send via Resend using RESEND_API_KEY + CONTACT_EMAIL_FROM
#                        (target state: use after destinbonfirecompany.com DNS is verified)
#   "fallback_sender"  - send via Resend using the fallback key + From address
#                        (e.g. route through the 30aflame.com sending domain while
#                         destinbonfirecompany.com DNS propagates)
#
# ⚠ PEAK SEASON NOTE: log_only is safe because nothing is lost, but
# nobody is notified in real-time - you'd need to open the log file to see
# inquiries. Before peak booking season (May onward), switch to
# fallback_sender (via 30aflame.com) or resend (once DNS is done) so the
# team gets an email the moment a customer submits the form.
CONTACT_EMAIL_MODE=log_only

# ---------------------------------------------------------------------------
# Resend - primary sender (destinbonfirecompany.com, once DNS is verified)
# ---------------------------------------------------------------------------
# Create an API key at https://resend.com/api-keys.
# "From" must be an address on a Resend-verified domain.
RESEND_API_KEY=
CONTACT_EMAIL_FROM="Destin Bonfire Company <bookings@destinbonfirecompany.com>"

# ---------------------------------------------------------------------------
# Resend - fallback sender (used when CONTACT_EMAIL_MODE=fallback_sender)
# ---------------------------------------------------------------------------
# Temporary sender used if destinbonfirecompany.com DNS is not yet configured.
# Point these at whatever already-verified Resend domain is available.
RESEND_API_KEY_FALLBACK=
CONTACT_EMAIL_FROM_FALLBACK="Destin Bonfire Company <bookings@30aflame.com>"

# ---------------------------------------------------------------------------
# Destination address + reply-to behavior
# ---------------------------------------------------------------------------
# Who receives inquiries. Can be changed without redeploy.
CONTACT_EMAIL_TO=bookings@destinbonfirecompany.com

# Optional. If unset, Reply-To is set to the form submitter's email so
# clicking "Reply" in Gmail goes directly back to the customer.
# Set this only if you want replies to route elsewhere (e.g. a support inbox).
# CONTACT_EMAIL_REPLY_TO=

# ============================================================================
# Admin dashboard at /admin
# ============================================================================
# Long random secret used to log into /admin. Generate one with:
#   openssl rand -hex 32
# Keep this in .env.local locally and in the Vercel project's encrypted env.
ADMIN_TOKEN=

# ============================================================================
# PostHog (admin dashboard analytics)
# ============================================================================
# Personal API key from PostHog → My Settings → Personal API Keys.
# RECOMMENDED: create a scoped key with read-only "Query" + "Project read"
# permissions rather than full Personal scope, then paste here.
POSTHOG_PERSONAL_API_KEY=

# Pick the region your PostHog project lives in.
#   US Cloud: https://us.posthog.com
#   EU Cloud: https://eu.posthog.com
POSTHOG_HOST=https://us.posthog.com

# Optional. Leave blank and the server picks the first project on the
# account at first request. Set explicitly if you have multiple projects.
POSTHOG_PROJECT_ID=

# Public PostHog project key (phc_*) - safe to expose on the client. Used
# by the PostHogProvider + posthog-server.ts. Get it via PostHog → Project
# Settings → Project API Key, or run:  node scripts/posthog-discover.mjs
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ============================================================================
# Supabase - contact form storage (admin dashboard reads from here)
# ============================================================================
# Project Settings → API:
#   • Project URL          → SUPABASE_URL
#   • service_role secret  → SUPABASE_SERVICE_ROLE_KEY  (SERVER-ONLY; bypasses RLS)
#
# Run the migration in supabase/migrations/0001_contact_submissions.sql
# once before the first deploy.
#
# If both vars are unset, contact submissions fall back to the local
# logs/contact-submissions.json file (dev-only - ephemeral on Vercel).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
